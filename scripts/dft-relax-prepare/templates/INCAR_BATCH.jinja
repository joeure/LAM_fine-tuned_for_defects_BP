SYSTEM   = {{ systemName }}
ENCUT    = {{ encut }}            # >= 1.3*ENMAX recommended for relax quality
EDIFF    = 1E-6                   # tighter electronic conv. for relax

# -------- performance knobs -------- #
{% if ideal %}
{% if isNotTest %}
NBANDS   = {{ nbands }}           # optional; otherwise let VASP choose
NCORE    = 2
{% endif %}
{% else %}
NBANDS   = {{ nbands }}
NCORE    = 2
{% endif %}
# Metal vs. semiconductor smearing
ISMEAR   = {{ 1 if isMetal else 0 }}   ; SIGMA = {{ 0.2 if isMetal else 0.05 }}
LREAL    = {{ lreal }}                 # Auto for big cells, .FALSE. for small cells
NELM     = {{ nelem }}                 # e.g. 120 for formal runs
ALGO     = {{ algo if ideal else "Fast" }}
{% if not ideal %}
AMIX     = 0.20
BMIX     = 0.0001
{% endif %}
PREC     = {{ prec }}

# ---- ionic relaxation (positions only) ----
IBRION   = 2                    # CG ionic optimizer
NSW      = {{ nsw|default(300) }}
ISIF     = 2                    # relax ions, keep cell fixed
EDIFFG   = -0.01                # stop when |F|max ≲ 0.01 eV/Å
POTIM    = 0.03                 # safe step for CG

# ---- 2-D specific ----
LDIPOL   = .TRUE.               # dipole correction for asymmetric slabs
IDIPOL   = 3                    # along z (c-axis)
# DIPOL  = 0.5 0.5 0.5          # set center if needed

# ---- SPIN ----
ISPIN    = 2
MAGMOM   = {{ magmom }}         # e.g. "1*0.5 179*0.0" or per-element blocks

# ---- book-keeping ----
LWAVE    = .FALSE.
LCHARG   = .FALSE.
