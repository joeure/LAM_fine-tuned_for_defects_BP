{% for system in system_infos %}

# ======================= Initialization =======================
units           metal                 # eV, Å (matches MACE docs)
atom_style      atomic
atom_modify     map yes               # consistent atom IDs (MACE docs)
newton          on
boundary        p p p

neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes  # recommended for minimize

# ====================== Read Structure ======================
read_data {{ system.structure_file }}

# ===== MACE potential (TorchScript .pt) =====================
# Use a model converted with create_lammps_model.py → *.model-lammps.pt
pair_style      mace/kk no_domain_decomposition
pair_coeff      * * {{ system.model_file }} {% for elem in system.elements %}{{ elem }} {% endfor %}

# =================== Paper-style Relaxation ==================
thermo          50
thermo_style    custom step pe fmax fnorm press lx ly lz

# (1) Short FIRE warmup to settle overlaps / big gradients
# timestep        0.001                 # ps (used by FIRE/quickmin only)
# min_style  fire/kk
# min_modify      dmax 0.04
# minimize        0.0 0.05  2000  4000  # etol, ftol, maxiter, maxeval

# (2) Final tighten with CG (positions only; fixed cell)
min_style  cg/kk
min_modify      dmax 0.03 line quadratic
minimize        1.0e-8 0.010  10000  100000
# NOTE: LAMMPS ftol is an upper bound on any force *component* (eV/Å),
# so ftol=0.010 is a close match to VASP’s |F|max ≤ 0.01 eV/Å target. :contentReference[oaicite:1]{index=1}

# ======================= Output =============================
write_data      {{ system.output_file }}
print           "Relaxation complete for {{ system.system_name }} → {{ system.output_file }}"

{% if not loop.last %}
clear
{% endif %}

{% endfor %}
print "End for systems bundle: {{ total_name }}."
